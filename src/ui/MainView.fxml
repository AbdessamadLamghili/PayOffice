<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.MainController"
            style="-fx-background-color: #f0f2f5;">

    <!-- ═══════════════════════════════════════════════════════════
         TOP BAR — Application Header
    ═══════════════════════════════════════════════════════════ -->
    <top>
        <HBox style="-fx-background-color: #1a2744; -fx-padding: 14 24; -fx-alignment: CENTER_LEFT; -fx-spacing: 12;">
            <Label text="🎓" style="-fx-font-size: 22px;"/>
            <VBox>
                <Label text="PayOffice" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Gestion des Frais d'Inscription Universitaires"
                       style="-fx-text-fill: #8fa3c8; -fx-font-size: 11px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnImporter"
                    text="📂  Importer CSV"
                    onAction="#handleImporterCSV"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-padding: 8 18; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════
         CENTER — Main Content Area
    ═══════════════════════════════════════════════════════════ -->
    <center>
        <SplitPane dividerPositions="0.55" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <!-- ─── LEFT PANEL: Student List ─────────────────────── -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                                     -fx-padding: 16;">
                <Label text="Liste des Étudiants"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                <Separator/>

                <!-- ── Search bar (v1.1) ── -->
                <HBox spacing="6" style="-fx-alignment: CENTER_LEFT;">
                    <TextField fx:id="fieldRecherche"
                               promptText="🔍  Rechercher par nom ou ID..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-border-color: #bdc3c7; -fx-border-radius: 5;
                                      -fx-background-radius: 5; -fx-padding: 6 10;
                                      -fx-font-size: 12px;"/>
                    <Button text="✕"
                            onAction="#handleEffacerRecherche"
                            style="-fx-background-color: #ecf0f1; -fx-text-fill: #7f8c8d;
                                   -fx-padding: 6 10; -fx-background-radius: 5;
                                   -fx-cursor: hand; -fx-font-size: 12px;">
                        <tooltip>
                            <Tooltip text="Effacer la recherche"/>
                        </tooltip>
                    </Button>
                </HBox>

                <TableView fx:id="tableEtudiants" VBox.vgrow="ALWAYS"
                           style="-fx-border-color: #e8ecf0; -fx-border-radius: 6;">
                    <columns>
                        <TableColumn fx:id="colId"      text="ID"     prefWidth="45"  style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colNom"     text="Nom"    prefWidth="100"/>
                        <TableColumn fx:id="colPrenom"  text="Prénom" prefWidth="100"/>
                        <TableColumn fx:id="colClasse"  text="Classe" prefWidth="70"  style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colFrais"   text="Frais (MAD)"   prefWidth="95" style="-fx-alignment: CENTER_RIGHT;"/>
                        <TableColumn fx:id="colPaye"    text="Payé (MAD)"    prefWidth="90" style="-fx-alignment: CENTER_RIGHT;"/>
                        <TableColumn fx:id="colRestant" text="Restant (MAD)" prefWidth="95" style="-fx-alignment: CENTER_RIGHT;"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun étudiant chargé. Importez un fichier CSV."
                               style="-fx-text-fill: #999; -fx-font-style: italic;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- ─── RIGHT PANEL: Student Info + Payment + History + Receipt ─ -->
            <VBox spacing="10">

                <!-- Student Info Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                             -fx-padding: 16;" spacing="8">
                    <Label text="Étudiant Sélectionné"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                    <Separator/>
                    <Label fx:id="labelNomEtudiant" text="—"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <GridPane hgap="16" vgap="6">
                        <!-- Frais total -->
                        <Label text="Frais d'inscription :" GridPane.columnIndex="0" GridPane.rowIndex="0"
                               style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="labelFraisTotal" text="—" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               style="-fx-font-weight: bold;"/>
                        <!-- Total payé -->
                        <Label text="Total payé :"       GridPane.columnIndex="0" GridPane.rowIndex="1"
                               style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="labelTotalPaye"  text="—" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               style="-fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
                        <!-- Solde restant -->
                        <Label text="Solde restant :"    GridPane.columnIndex="0" GridPane.rowIndex="2"
                               style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="labelSoldeRestant" text="—" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                        <!-- Statut -->
                        <Label text="Statut :"           GridPane.columnIndex="2" GridPane.rowIndex="0"
                               style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="labelStatut"       text="—" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    </GridPane>
                </VBox>

                <!-- Payment Form Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                             -fx-padding: 16;" spacing="10">
                    <Label text="Enregistrer un Paiement"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                    <Separator/>
                    <HBox spacing="10" style="-fx-alignment: CENTER_LEFT;">
                        <Label text="Montant (MAD) :" style="-fx-text-fill: #2c3e50;"/>
                        <TextField fx:id="fieldMontant"
                                   promptText="Ex: 2500"
                                   prefWidth="160"
                                   style="-fx-border-color: #bdc3c7; -fx-border-radius: 5;
                                          -fx-background-radius: 5; -fx-padding: 6 10;"
                                   disable="true"/>
                        <Button fx:id="btnPayer"
                                text="✔  Valider le Paiement"
                                onAction="#handlePayer"
                                disable="true"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 7 16;
                                       -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </HBox>
                    <Label fx:id="labelMessage" text="" wrapText="true"
                           style="-fx-font-size: 12px;"/>
                </VBox>

                <!-- Payment History Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                             -fx-padding: 16;" spacing="8" VBox.vgrow="SOMETIMES">
                    <HBox style="-fx-alignment: CENTER_LEFT;" spacing="10">
                        <Label text="Historique des Paiements"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAnnulerPaiement"
                                text="↶  Annuler le Paiement"
                                onAction="#handleAnnulerPaiement"
                                disable="true"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                       -fx-padding: 5 12; -fx-background-radius: 5; -fx-cursor: hand;
                                       -fx-font-size: 11px;">
                            <tooltip>
                                <Tooltip text="Annuler le paiement sélectionné"/>
                            </tooltip>
                        </Button>
                    </HBox>
                    <Separator/>
                    <TableView fx:id="tablePaiements" prefHeight="130" VBox.vgrow="ALWAYS"
                               style="-fx-border-color: #e8ecf0; -fx-border-radius: 6;">
                        <columns>
                            <TableColumn fx:id="colPaiementId" text="#"           prefWidth="45"
                                         style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colMontant"    text="Montant (MAD)" prefWidth="130"
                                         style="-fx-alignment: CENTER_RIGHT;"/>
                            <TableColumn fx:id="colDate"       text="Date &amp; Heure" prefWidth="180"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun paiement enregistré."
                                   style="-fx-text-fill: #999; -fx-font-style: italic;"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- Receipt Area Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);
                             -fx-padding: 16;" spacing="8" VBox.vgrow="ALWAYS">
                    <HBox style="-fx-alignment: CENTER_LEFT;" spacing="10">
                        <Label text="Reçu Généré"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnExporterRecu"
                                text="💾  Exporter en TXT"
                                onAction="#handleExporterRecu"
                                style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                                       -fx-padding: 5 12; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    </HBox>
                    <Separator/>
                    <TextArea fx:id="areaRecu"
                              editable="false"
                              VBox.vgrow="ALWAYS"
                              prefHeight="160"
                              promptText="Le reçu apparaîtra ici après chaque paiement..."
                              style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;
                                     -fx-background-color: #fafafa; -fx-border-color: #e8ecf0;
                                     -fx-border-radius: 5;"/>
                </VBox>

            </VBox>
        </SplitPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════
         BOTTOM — Status Bar
    ═══════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 6 16; -fx-border-color: #bdc3c7;
                     -fx-border-width: 1 0 0 0;" spacing="20">
            <Label text="PayOffice v1.1  —  Persistance CSV activee" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="🟢 Vert = Soldé  |  🟡 Jaune = Partiel  |  ⚪ Blanc = Non payé"
                   style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
